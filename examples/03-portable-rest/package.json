{
  "name": "yasws-example-portable-rest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build:bundle": "esbuild dist/wasi.js --bundle --format=esm --platform=node --target=es2022 --external:wasi:* --outfile=build/bundle.js",
    "build:wasm": "jco componentize build/bundle.js --wit wit/ --world-name app --out build/app.wasm",
    "build:node": "npm run build:ts",
    "build:wasi": "npm run build:ts && npm run build:bundle && npm run build:wasm",
    "build": "npm run build:wasi",
    "start:node": "node --enable-source-maps dist/node.js",
    "serve:wasi": "wasmtime serve -Scli --addr 0.0.0.0:8000 build/app.wasm",
    "clean": "rm -rf dist build"
  },
  "dependencies": {
    "yasws": "file:../.."
  },
  "devDependencies": {
    "@bytecodealliance/componentize-js": "^0.18.0",
    "@bytecodealliance/jco": "^1.8.0",
    "@types/node": "^24.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.2"
  }
}
